@prefix : <http://data.treehouse.example/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:siderealOrbitalPeriod a rdf:Property ;
    rdfs:label "sidereal orbital period"@en ;
    rdfs:subPropertyOf :orbitalPeriod,
        :orbitalProperty, :siderealOrbitalPeriod .

:orbitalPeriod a rdf:Property ;
    rdfs:label "orbital period"@en ;
    rdfs:subPropertyOf :orbitalProperty, :orbitalPeriod .

:orbitalProperty a rdf:Property ;
    rdfs:label "orbital property"@en ;
    rdfs:subPropertyOf :orbitalProperty .